{
  "name": "base56",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:only": "concurrently -k \"npm run dev:vite\" \"npm run dev:server\"",
    "dev:vite": "vite --port 5174 --strictPort",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build",
    "preview": "vite preview",
    "db:push": "npm run db:push --prefix server",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:migrate:deploy": "npm run db:migrate:deploy --prefix server",
    "db:local:up": "docker compose up -d",
    "db:local:down": "docker compose down",
    "db:local:brew": "sh scripts/setup-local-postgres-brew.sh",
    "db:local:migrate": "npm run db:migrate:deploy --prefix server"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.25",
    "@base44/vite-plugin": "^1.0.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.475.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.1.0"
  }
}
