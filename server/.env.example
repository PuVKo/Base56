# Локально — SQLite (одна ветка git; на сервере Timeweb — Postgres).
# Файл БД: server/prisma/sqlite/dev.db (путь относительно каталога со схемой sqlite)
DATABASE_URL="file:./dev.db"
#
# После смены SQLite ↔ Postgres перезапустите сервер dev (в нём есть prisma generate) или вручную:
#   cd server && node scripts/prisma-with-schema.mjs generate
# Иначе @prisma/client останется сгенерированным под предыдущий провайдер — запросы к БД будут падать.

# Локально оставьте PORT=3001. На Timeweb Apps закомментируйте PORT — платформа задаёт свой
# (часто 8080); иначе healthcheck может стучаться не в тот порт и деплой будет «висеть» бесконечно.
# Если в образ попал .env с PORT=3001 при БД twc1.net, env.js сбросит PORT — приложение слушает 8080 по умолчанию.
PORT=3001

# При запуске node src/index.js подхватывается этот файл (server/.env) через dotenv.

# Первый запуск / после клона:
#   cd server && node scripts/prisma-with-schema.mjs migrate deploy
# или из корня: npm run db:migrate:deploy --prefix server
# Затем: npm run dev:only (из корня репо)

# Схемы: prisma/sqlite/ (локально) и prisma/postgres/ (облако). Меняя модели — правьте ОБА schema.prisma.

# Продакшен (Timeweb): в панели приложения задайте DATABASE_URL=postgresql://...?sslmode=require
# Для connect-pg-simple / скриптов на `pg`: хост *.twc1.net обрабатывается автоматически; иначе при
# SELF_SIGNED_CERT_IN_CHAIN задайте PGSSL_REJECT_UNAUTHORIZED=0 (TLS остаётся, без проверки цепочки).
# PGSSL_REJECT_UNAUTHORIZED=0
# Timeweb Apps — команда запуска (НЕ dist/index.js: такого файла нет; dist — это фронт в корне репо):
#   pm2 start --no-daemon ecosystem.config.cjs
# Если «путь к проекту» = /server (только каталог server): node src/index.js
# Если «путь к проекту» = корень репозитория (есть папка server/): node start-timeweb.mjs  (файл в корне репо)
# или: npm run start:timeweb
# Сборка: npm install && npm run build:server
#   путь /server — скрипт из server/package.json;
#   путь к корню репо — то же имя в корневом package.json (прокси: ставит зависимости server/ и вызывает сборку).
# Репозиторий на сервере должен быть целиком (родитель server/ с vite.config.js), иначе build-server.sh не соберёт ../dist.
# /api/health в коде стоит ДО session/БД — healthcheck не должен зависеть от Postgres; если деплой всё ещё висит — пробуйте node src/index.js вместо PM2.

# Опционально локальный Postgres вместо SQLite: docker compose up -d в корне репо + DATABASE_URL=postgresql://base56:base56@localhost:5432/base56

# Опционально: если задано, POST /api/admin/reset-bookings требует заголовок X-Admin-Reset-Secret с этим значением
# ADMIN_RESET_SECRET=...

# Сессии: в production задайте SESSION_SECRET ≥16 символов. Если не задан — сервер поднимется с производным
# секретом от DATABASE_URL/APP_PUBLIC_URL (см. server/src/session.js), но лучше задать свой SESSION_SECRET в панели.
# SESSION_SECRET=замените_на_случайную_строку
# HTTP без TLS: иначе cookie с secure не сохранится — задайте SESSION_COOKIE_SECURE=0
# SESSION_COOKIE_SECURE=0
# Публичный URL фронта — для ссылок в письмах (регистрация / сброс пароля)
# APP_PUBLIC_URL=http://localhost:5174
# Доп. origin для CORS (через запятую), если фронт не на localhost:5174. В список также входит APP_PUBLIC_URL.
# CORS_ORIGINS=https://app.example.com

# LLM-ассистент (OpenRouter, OpenAI-совместимый API — см. https://openrouter.ai/docs).
# Ключ: https://openrouter.ai/keys — только на сервере, в репозиторий не коммитить.
# Нужен положительный баланс: https://openrouter.ai/settings/credits (иначе «Insufficient credits»).
# OPENROUTER_API_KEY=sk-or-v1-...
# Модель (slug OpenRouter). По умолчанию: openai/gpt-4o-mini (есть tool use; дешевле крупных моделей).
# Без tool use ассистент не сможет вызывать list_bookings и т.д. — не все дешёвые модели поддерживаются провайдерами.
# ASSISTANT_MODEL=anthropic/claude-3.5-haiku
# Опционально для рейтинга в OpenRouter: публичный URL приложения и название.
# OPENROUTER_HTTP_REFERER=https://app.base56.ru
# OPENROUTER_APP_TITLE=Base56
# Отключить эндпоинт /api/assistant/chat без удаления кода:
# ASSISTANT_DISABLED=1

# Почта: при заданном RUSENDER_API_KEY + MAIL_FROM — RuSender Email API; иначе SMTP.
# RuSender: https://rusender.ru/developer/api/email/ — ключ в X-Api-Key, домен отправителя подтверждён в панели.
# RUSENDER_API_KEY=...
# MAIL_FROM=Base56 <noreply@base56.ru>
# Опционально: RUSENDER_API_URL, RUSENDER_API_TIMEOUT_MS
#
# SMTP (Timeweb и др.): если RuSender не задан или без MAIL_FROM — используется SMTP.
# SMTP_HOST=smtp.timeweb.ru
# SMTP_PORT=465
# SMTP_SECURE=1
# SMTP_USER=mailbox@ваш-домен.ru
# SMTP_PASS=...
# MAIL_FROM=Base56 <mailbox@ваш-домен.ru>
# Для отладки без отправки: MAIL_MODE=console
# MAIL_MODE=console

# После миграции со старых данных без пользователей создаётся migrated-owner@base56.local — пароль ChangeMeNow123! (смените через «Забыли пароль»)

# CLI: export-bookings — пользователь по умолчанию первый в БД; иначе укажите cuid:
# BASE56_SCRIPT_USER_ID=...
